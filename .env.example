# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# ── Database ─────────────────────────────────────────────
DB_ROOT_PASSWORD=changeme_root
DB_NAME=nfc_health_db
DB_USER=nfc_user
DB_PASSWORD=changeme_nfc

# ── JWT ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_64_CHARS_LONG

# ── Spring ───────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── Ports ────────────────────────────────────────────────
PATIENT_PORTAL_PORT=3000
HOSPITAL_PORTAL_PORT=3001
BACKEND_PORT=8080

# ── CORS (Cloud Deployment) ──────────────────────────────
# Comma-separated list of allowed frontend origins (set on Render)
# CORS_ALLOWED_ORIGINS=https://patient-portal.vercel.app,https://hospital-portal.vercel.app

# ── Frontend API URL (Cloud Deployment) ──────────────────
# Set in Vercel project settings → Environment Variables
# VITE_API_URL=https://your-backend.onrender.com/api
